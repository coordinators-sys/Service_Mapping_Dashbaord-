# Secrets — env vars are set in the Vercel project settings, never uploaded
.env
.env.*

# Dev-time source data (only the generated data/ + geo/ files, plus
# assets/icons/ + assets/images/, are needed at runtime). Leading "/" anchors
# these to the repo root — without it, "icons/" and "logo/" also matched (and
# wrongly excluded) assets/icons/ and assets/logo/, breaking the sector icons
# in production.
/Masterlist/
/Somali Maps/
/logo/
/icons/
/build_data.py
/requirements-dev.txt
/scripts/

# Local clutter
__pycache__/
*.pyc
